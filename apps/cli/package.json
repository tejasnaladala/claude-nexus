{
  "name": "claude-nexus",
  "version": "0.1.0",
  "description": "CLI for Claude Nexus multi-agent coordination system",
  "main": "./dist/index.js",
  "bin": {
    "nexus": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
